# -----------------------------------------------------------------------------
# Network bind configuration
# Change BIND_IP to 0.0.0.0 to expose services on all interfaces, or to a
# specific host IP to bind only to that address. Default (127.0.0.1) keeps
# the stack reachable only from the local machine.
# -----------------------------------------------------------------------------
BIND_IP=127.0.0.1

# Service ports (host-side)
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090
LOKI_PORT=3100
ALLOY_PORT=12345

# Grafana admin credentials
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Image versions (latest stable as of June 2026)
PROMETHEUS_VERSION=v3.12.0
LOKI_VERSION=3.7.2
GRAFANA_VERSION=13.0.2
ALLOY_VERSION=v1.17.0

# -----------------------------------------------------------------------------
# Host filesystem paths used by Alloy to read container logs.
# On a standard Docker install the container JSON logs live under
# /var/lib/docker/containers/<id>/<id>-json.log, so DOCKER_CONTAINERS_DIR is
# the default. Override here if your Docker data root is elsewhere
# (check `docker info | grep "Docker Root Dir"`).
# -----------------------------------------------------------------------------
DOCKER_CONTAINERS_DIR=/srv/docker/overlays/containers
DOCKER_SOCK=/var/run/docker.sock